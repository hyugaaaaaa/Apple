{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2022": true,
    "serviceworker": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "globals": {
    "WebSocket": "readonly"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_", "caughtErrors": "none" }
    ],
    "no-undef": "error",
    "no-redeclare": "error",
    "no-dupe-keys": "error",
    "no-dupe-args": "error",
    "no-dupe-else-if": "error",
    "no-irregular-whitespace": "warn",
    "no-unreachable": "warn",
    "no-constant-condition": ["warn", { "checkLoops": false }],
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-shadow-restricted-names": "error",
    "no-prototype-builtins": "off",
    "no-async-promise-executor": "warn",
    "use-isnan": "error",
    "valid-typeof": "error",
    "eqeqeq": ["warn", "smart"],
    "no-var": "warn",
    "prefer-const": "warn"
  },
  "overrides": [
    {
      "files": ["public/sw.js"],
      "env": { "browser": false, "serviceworker": true }
    },
    {
      "files": ["relay/**/*.js"],
      "env": { "browser": false, "node": true }
    },
    {
      "files": ["public/**/*.js"],
      "env": { "browser": true, "node": false }
    }
  ]
}
